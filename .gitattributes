# Auto detect text files and normalize to LF
* text=auto eol=lf

# Explicitly declare text files
*.c     text eol=lf
*.cpp   text eol=lf
*.h     text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf
*.md    text eol=lf
*.txt   text eol=lf

# Windows-specific files can keep CRLF
*.vcxproj       text eol=crlf
*.vcxproj.filters text eol=crlf
*.sln           text eol=crlf
*.bat           text eol=crlf

# Binary files
*.ttf   binary
*.png   binary
*.jpg   binary
*.prc   binary
